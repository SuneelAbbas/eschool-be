						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"institute\": {\n        \"name\": \"ABC School\",\n        \"logo\": null,\n        \"address\": \"123 Education Street\",\n        \"contact_email\": \"contact@abcschool.com\",\n        \"contact_phone\": \"+92-300-1234567\",\n        \"type\": \"private\",\n        \"city\": \"Lahore\",\n        \"no_of_students\": 500,\n        \"description\": \"A premier educational institution\",\n        \"status\": \"active\"\n    }\n}",
